    "@types/qrcode": "^1.5.5",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "15.2.3",
    "postcss": "^8",
    "tailwindcss": "^3.4.0",
    "typescript": "^5",
    "wrangler": "^3.78.0"
